{
  "name": "@vibestudio/runner",
  "version": "1.0.0",
  "description": "Story Runner - Orchestrates workflow execution using Claude Code CLI sessions",
  "main": "dist/index.js",
  "bin": {
    "story-runner": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:run": "node dist/index.js start",
    "start:resume": "node dist/index.js resume",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "docker:build": "docker build -t vibestudio/runner:latest .",
    "docker:run": "docker compose -f docker-compose.runner.yml up",
    "docker:run:detached": "docker compose -f docker-compose.runner.yml up -d"
  },
  "keywords": [
    "vibestudio",
    "story-runner",
    "workflow",
    "claude-code",
    "orchestration"
  ],
  "author": "VibeStudio",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
