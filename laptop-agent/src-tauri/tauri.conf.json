{
  "productName": "VibeStudio Agent",
  "version": "0.1.0",
  "identifier": "com.vibestudio.agent",
  "build": {
    "beforeDevCommand": "npm run app:dev",
    "beforeBuildCommand": "npm run app:build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist/app"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/vibestudio-agent"]
  },
  "app": {
    "windows": [
      {
        "title": "VibeStudio Agent",
        "width": 400,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "alwaysOnTop": false,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
