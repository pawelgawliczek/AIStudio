{
  "name": "@vibestudio/laptop-agent",
  "version": "1.0.0",
  "description": "Remote execution agent for VibeStudio - runs on local machine where Claude Code operates",
  "main": "dist/index.js",
  "bin": {
    "vibestudio-agent": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "app:dev": "vite --config vite.config.ts",
    "app:build": "vite build --config vite.config.ts"
  },
  "keywords": [
    "vibestudio",
    "remote-agent",
    "transcript-analysis",
    "claude-code"
  ],
  "author": "VibeStudio",
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "@vibestudio/mcp-http-client": "file:../sdk/mcp-http-client",
    "axios": "^1.6.2",
    "better-sqlite3": "^9.2.2",
    "chokidar": "^4.0.3",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.7.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "winston-loki": "^6.1.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.6",
    "@types/better-sqlite3": "^7.6.9",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2",
    "vite": "^5.4.11"
  }
}
