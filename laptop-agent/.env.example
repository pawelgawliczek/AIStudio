# VibeStudio Remote Agent Configuration
# Copy to ~/.vibestudio/config.json or use environment variables

# Server connection
SERVER_URL=https://vibestudio.example.com
# For local development:
# SERVER_URL=http://127.0.0.1:3001

# Pre-shared secret for initial registration
AGENT_SECRET=your-secret-here-change-in-production

# Agent identification
AGENT_HOSTNAME=my-laptop

# Script capabilities (comma-separated)
AGENT_CAPABILITIES=parse-transcript,analyze-story-transcripts,list-transcripts

# Project path (where Claude Code runs)
PROJECT_PATH=/path/to/AIStudio

# Logging
LOG_LEVEL=info

# ST-351: Enable/disable initial artifact sync on startup (default: true)
# Set to 'false' to disable processing of existing artifact files on agent restart
SYNC_EXISTING_ARTIFACTS=true
