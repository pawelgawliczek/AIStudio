{
  "mcpServers": {
    "aistudio": {
      "command": "npx",
      "args": [
        "tsx",
        "backend/src/mcp/server.ts"
      ],
      "cwd": "/opt/stack/AIStudio",
      "env": {
        "DATABASE_URL": "postgresql://postgres:CHANGE_ME_POSTGRES_PASSWORD@127.0.0.1:5432/aistudio?schema=public",
        "NODE_ENV": "development",
        "MCP_CONFIG_TEST": "CONFIG_UPDATED_AT_20_14"
      },
      "description": "AI Studio MCP Server for project and story management (Development Mode)"
    }
  }
}
