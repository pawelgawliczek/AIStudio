// AI Studio MCP Control Plane - Database Schema
// Based on req.md Section 20 and architecture.md

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), vector, pgTrgm(map: "pg_trgm")]
}

// ============================================================================
// CORE PROJECT MANAGEMENT
// ============================================================================

model User {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name         String
  email        String   @unique
  password     String // bcrypt hashed
  role         UserRole
  refreshToken String?  @map("refresh_token") // JWT refresh token (hashed)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  createdStories         Story[]          @relation("CreatedStories")
  createdUseCaseVersions UseCaseVersion[]
  assignedTestCases      TestCase[]       @relation("TestCaseAssignee")
  createdTestCases       TestCase[]       @relation("TestCaseCreator")

  @@map("users")
}

model Project {
  id            String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name          String        @unique
  description   String?
  repositoryUrl String?       @map("repository_url")
  localPath     String?       @map("local_path") // Local path to git repository for code analysis (Docker container path)
  hostPath      String?       @map("host_path") // Host filesystem path for transcript tracking (where Claude Code runs)
  status        ProjectStatus @default(active)
  taxonomy      Json?         // ST-207: Controlled vocabulary for use case areas (array of strings)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  epics                Epic[]
  stories              Story[]
  useCases             UseCase[]
  commits              Commit[]
  testCases            TestCase[]
  agents               Agent[]
  frameworks           AgentFramework[]
  runs                 Run[]
  releases             Release[]
  auditLogs            AuditLog[]
  codeMetrics          CodeMetrics[]
  codeMetricsSnapshots CodeMetricsSnapshot[]
  components           Component[]
  workflows            Workflow[]
  workflowRuns         WorkflowRun[]
  defectsNew           DefectNew[]
  activeWorkflows      ActiveWorkflow[]
  metricsAggregations  MetricsAggregation[]
  fileUseCaseLinks     FileUseCaseLink[]
  otelEvents           OtelEvent[]
  approvalRequests     ApprovalRequest[]  // ST-148: Approval gates
  apiKeys              ApiKey[]           // ST-163: MCP HTTP API keys

  @@map("projects")
}

// ============================================================================
// ST-163: MCP HTTP API KEYS
// ============================================================================

// ApiKey - API keys for MCP HTTP transport authentication
model ApiKey {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  keyHash     String    @unique @map("key_hash")     // bcrypt hash of the full key
  keyPrefix   String    @unique @map("key_prefix")   // First 12 chars for fast lookup

  name        String
  description String?

  createdAt   DateTime  @default(now()) @map("created_at")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")           // Soft delete

  createdBy   String?   @map("created_by")
  metadata    Json?                                   // Rate limits, IP whitelist, allowed tools

  @@index([keyPrefix])
  @@index([projectId])
  @@map("api_keys")
}

model Epic {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId   String     @map("project_id") @db.Uuid
  key         String // e.g., EP-1, unique within project
  title       String
  description String?
  status      EpicStatus @default(planning)
  priority    Int        @default(0)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relations
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stories      Story[]
  commits      Commit[]
  workflowRuns WorkflowRun[]

  @@unique([projectId, key])
  @@index([projectId, status])
  @@map("epics")
}

model Story {
  id                  String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId           String      @map("project_id") @db.Uuid
  epicId              String?     @map("epic_id") @db.Uuid
  key                 String // e.g., ST-1, unique within project
  type                StoryType   @default(feature)
  title               String
  description         String?
  summary             String?     @db.VarChar(300) // AI-generated 2-sentence summary for token efficiency
  status              StoryStatus @default(planning)
  priority            Int         @default(0)
  businessImpact      Int?        @map("business_impact")
  businessComplexity  Int?        @map("business_complexity")
  technicalComplexity Int?        @map("technical_complexity")
  estimatedTokenCost  Int?        @map("estimated_token_cost")
  assignedFrameworkId String?     @map("assigned_framework_id") @db.Uuid
  assignedWorkflowId  String?     @map("assigned_workflow_id") @db.Uuid
  createdById         String      @map("created_by") @db.Uuid

  // Analysis fields (filled by agents)
  // @deprecated ST-152: Use Artifact system instead - these fields will be removed in a future release
  contextExploration String? @map("context_exploration") @db.Text /// @deprecated Use Artifact system (ST-152)
  baAnalysis         String? @map("ba_analysis") @db.Text /// @deprecated Use Artifact system (ST-152)
  designerAnalysis   String? @map("designer_analysis") @db.Text /// @deprecated Use Artifact system (ST-152)
  architectAnalysis  String? @map("architect_analysis") @db.Text /// @deprecated Use Artifact system (ST-152)

  // Analysis timestamps
  contextExploredAt   DateTime? @map("context_explored_at")
  baAnalyzedAt        DateTime? @map("ba_analyzed_at")
  designerAnalyzedAt  DateTime? @map("designer_analyzed_at")
  architectAnalyzedAt DateTime? @map("architect_analyzed_at")

  // Workflow phase tracking (Epic EP-7 - ST-38)
  currentPhase StoryPhase? @map("current_phase")

  // Metadata (metrics, framework info, etc.)
  metadata Json? // Stores aggregated metrics, framework info, and other dynamic data

  // Defect leakage tracking
  defectLeakageCount Int @default(0) @map("defect_leakage_count")

  // ST-84: Manual approval for direct commits (solo development)
  manualApproval      Boolean?  @map("manual_approval") @default(false)
  approvedBy          String?   @map("approved_by")
  approvedAt          DateTime? @map("approved_at")
  approvalExpiresAt   DateTime? @map("approval_expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  project           Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  epic              Epic?              @relation(fields: [epicId], references: [id], onDelete: SetNull)
  createdBy         User               @relation("CreatedStories", fields: [createdById], references: [id])
  assignedFramework AgentFramework?    @relation(fields: [assignedFrameworkId], references: [id], onDelete: SetNull)
  assignedWorkflow  Workflow?          @relation(fields: [assignedWorkflowId], references: [id], onDelete: SetNull)
  subtasks          Subtask[]
  useCaseLinks      StoryUseCaseLink[]
  commits           Commit[]
  runs              Run[]
  workflowRuns      WorkflowRun[]
  testExecutions    TestExecution[]
  defect            Defect?
  defectsIntroduced DefectNew[]        @relation("DefectsIntroducedByStory")
  defectsFound      DefectNew[]        @relation("DefectsFoundInStory")
  releaseItems      ReleaseItem[]
  worktrees         Worktree[]
  testQueueEntries  TestQueue[]
  pullRequests      PullRequest[]
  deploymentLocks   DeploymentLock[]
  deploymentLogs    DeploymentLog[]
  artifacts         Artifact[] // ST-214: Story-scoped artifacts

  @@unique([projectId, key])
  @@index([projectId, status, type])
  @@index([epicId])
  @@index([assignedFrameworkId])
  @@index([assignedWorkflowId])
  @@map("stories")
}

model Subtask {
  id           String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  storyId      String        @map("story_id") @db.Uuid
  key          String? // optional key within story
  title        String
  description  String?
  assigneeType AssigneeType  @default(agent) @map("assignee_type")
  assigneeId   String?       @map("assignee_id") @db.Uuid
  status       SubtaskStatus @default(todo)

  // Link to component run (for agent-created subtasks)
  componentRunId String? @map("component_run_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  story        Story         @relation(fields: [storyId], references: [id], onDelete: Cascade)
  runs         Run[]
  componentRun ComponentRun? @relation(fields: [componentRunId], references: [id], onDelete: SetNull)

  @@index([storyId, status])
  @@index([componentRunId])
  @@map("subtasks")
}

// ============================================================================
// CODE QUALITY METRICS
// ============================================================================

model CodeMetrics {
  id                   String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId            String   @map("project_id") @db.Uuid
  filePath             String   @map("file_path")
  language             String? // e.g., TypeScript, Python, etc.
  linesOfCode          Int      @map("lines_of_code")
  cyclomaticComplexity Float    @map("cyclomatic_complexity")
  cognitiveComplexity  Float    @map("cognitive_complexity")
  maintainabilityIndex Float    @map("maintainability_index") // 0-100 scale
  testCoverage         Float?   @default(0.0) @map("test_coverage") // 0-100%
  churnRate            Int      @map("churn_rate") // Number of changes in last 90 days
  churnCount           Int      @default(0) @map("churn_count") // Total number of changes
  riskScore            Float    @default(0.0) @map("risk_score") // 0-100 scale. Formula: round((complexity/10) × churn × (100-maintainability)). Capped at 100. (ST-28)
  codeSmellCount       Int      @map("code_smell_count")
  criticalIssues       Int      @default(0) @map("critical_issues")
  lastModified         DateTime @default(now()) @map("last_modified")
  lastAnalyzedAt       DateTime @map("last_analyzed_at")
  metadata             Json? // Stores code smells, function metrics, imports, importedBy, etc.
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, filePath], name: "projectId_filePath")
  @@index([projectId, maintainabilityIndex])
  @@index([projectId, riskScore(sort: Desc)])
  @@map("code_metrics")
}

// ST-18: Historical snapshots for Code Quality trends
model CodeMetricsSnapshot {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  snapshotDate DateTime @default(now()) @map("snapshot_date")

  // Aggregated project metrics at time of snapshot
  totalFiles    Int   @map("total_files")
  totalLOC      Int   @map("total_loc")
  avgComplexity Float @map("avg_complexity")
  avgCoverage   Float @map("avg_coverage")
  healthScore   Float @map("health_score")
  techDebtRatio Float @map("tech_debt_ratio")

  // Optional: Store additional metadata (locByLanguage, topHotspots, etc.)
  metadata Json? // { locByLanguage: {...}, topHotspots: [...] }

  // Provenance tracking
  analysisRunId String?  @map("analysis_run_id") // Link to analysis job if available
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Constraints: Prevent duplicate snapshots for same date
  @@unique([projectId, snapshotDate])
  @@index([projectId, snapshotDate(sort: Desc)])
  @@index([projectId, createdAt(sort: Desc)])
  @@map("code_metrics_snapshots")
}

// ============================================================================
// USE CASES & REQUIREMENTS
// ============================================================================

model UseCase {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  key       String // unique within project
  title     String
  area      String? // screen/flow/feature area
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  project    Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions   UseCaseVersion[]
  storyLinks StoryUseCaseLink[]
  testCases  TestCase[]
  fileLinks  FileUseCaseLink[]

  @@unique([projectId, key])
  @@index([projectId, area])
  @@map("use_cases")
}

model UseCaseVersion {
  id             String                       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  useCaseId      String                       @map("use_case_id") @db.Uuid
  version        Int
  summary        String?
  content        String // markdown or JSON
  embedding      Unsupported("vector(1536)")? // pgvector for semantic search
  createdById    String                       @map("created_by") @db.Uuid
  createdAt      DateTime                     @default(now()) @map("created_at")
  linkedStoryId  String?                      @map("linked_story_id") @db.Uuid
  linkedDefectId String?                      @map("linked_defect_id") @db.Uuid

  // Relations
  useCase   UseCase @relation(fields: [useCaseId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id])

  @@unique([useCaseId, version])
  @@index([useCaseId])
  @@map("use_case_versions")
}

model StoryUseCaseLink {
  storyId   String          @map("story_id") @db.Uuid
  useCaseId String          @map("use_case_id") @db.Uuid
  relation  UseCaseRelation @default(implements)
  createdAt DateTime        @default(now()) @map("created_at")

  // Relations
  story   Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  useCase UseCase @relation(fields: [useCaseId], references: [id], onDelete: Cascade)

  @@id([storyId, useCaseId])
  @@map("story_use_case_links")
}

model FileUseCaseLink {
  id        String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId String @map("project_id") @db.Uuid
  filePath  String @map("file_path") // Relative path from repo root
  useCaseId String @map("use_case_id") @db.Uuid

  // Confidence and provenance
  confidence Float         @default(1.0) // 0.0-1.0
  source     MappingSource // How was this link created?

  // Metadata
  firstSeenAt DateTime @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime @updatedAt @map("last_seen_at")
  occurrences Int      @default(1) // How many times confirmed

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  useCase UseCase @relation(fields: [useCaseId], references: [id], onDelete: Cascade)

  @@unique([projectId, filePath, useCaseId])
  @@index([projectId, filePath])
  @@index([projectId, useCaseId])
  @@index([projectId, confidence(sort: Desc)])
  @@map("file_use_case_links")
}

// ============================================================================
// DEFECTS / BUGS
// ============================================================================

model Defect {
  storyId        String         @id @map("story_id") @db.Uuid
  originStoryId  String?        @map("origin_story_id") @db.Uuid
  originStage    OriginStage?   @map("origin_stage")
  discoveryStage DiscoveryStage @map("discovery_stage")
  severity       DefectSeverity

  // Relations
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@map("defects")
}

// ============================================================================
// CODE, COMMITS, TESTS
// ============================================================================

model Commit {
  hash      String   @id
  projectId String   @map("project_id") @db.Uuid
  author    String
  timestamp DateTime @db.Timestamptz
  message   String
  storyId   String?  @map("story_id") @db.Uuid
  epicId    String?  @map("epic_id") @db.Uuid

  // Relations
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  story          Story?          @relation(fields: [storyId], references: [id], onDelete: SetNull)
  epic           Epic?           @relation(fields: [epicId], references: [id], onDelete: SetNull)
  files          CommitFile[]
  testExecutions TestExecution[]

  @@index([projectId, timestamp])
  @@index([storyId])
  @@map("commits")
}

model CommitFile {
  id               BigInt   @id @default(autoincrement())
  commitHash       String   @map("commit_hash")
  filePath         String   @map("file_path")
  locAdded         Int      @default(0) @map("loc_added")
  locDeleted       Int      @default(0) @map("loc_deleted")
  complexityBefore Int?     @map("complexity_before")
  complexityAfter  Int?     @map("complexity_after")
  coverageBefore   Decimal? @map("coverage_before") @db.Decimal(5, 2)
  coverageAfter    Decimal? @map("coverage_after") @db.Decimal(5, 2)

  // Relations
  commit Commit @relation(fields: [commitHash], references: [hash], onDelete: Cascade)

  @@index([commitHash])
  @@index([filePath])
  @@map("commit_files")
}

model TestCase {
  id          String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId   String  @map("project_id") @db.Uuid
  useCaseId   String  @map("use_case_id") @db.Uuid
  key         String // unique within project (e.g., TC-AUTH-101)
  title       String
  description String?

  // Test details
  testLevel       TestCaseType  @map("test_level") // unit, integration, e2e
  priority        TestPriority? @default(medium)
  preconditions   String?
  testSteps       String?       @map("test_steps")
  expectedResults String?       @map("expected_results")
  testData        Json?         @map("test_data")

  // Implementation
  status       TestCaseStatus @default(pending)
  testFilePath String?        @map("test_file_path")
  assignedToId String?        @map("assigned_to") @db.Uuid

  // Metadata (coverage stats, execution history, etc.)
  metadata Json? // Additional test case data

  // Audit
  createdById String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  project    Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  useCase    UseCase         @relation(fields: [useCaseId], references: [id], onDelete: Cascade)
  assignedTo User?           @relation("TestCaseAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User            @relation("TestCaseCreator", fields: [createdById], references: [id], onDelete: Cascade)
  executions TestExecution[]

  @@unique([projectId, key])
  @@index([projectId, testLevel])
  @@index([useCaseId])
  @@index([status])
  @@map("test_cases")
}

model TestExecution {
  id         String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  testCaseId String  @map("test_case_id") @db.Uuid
  storyId    String? @map("story_id") @db.Uuid
  commitHash String? @map("commit_hash")

  // Execution details
  executedAt   DateTime            @map("executed_at") @db.Timestamptz
  status       TestExecutionStatus
  durationMs   Int?                @map("duration_ms")
  errorMessage String?             @map("error_message")

  // Coverage data (from CI reports)
  coveragePercentage Decimal? @map("coverage_percentage") @db.Decimal(5, 2)
  linesCovered       Int?     @map("lines_covered")
  linesTotal         Int?     @map("lines_total")

  // CI/CD context
  ciRunId     String? @map("ci_run_id")
  environment String? // dev, staging, prod

  // Relations
  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  story    Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)
  commit   Commit?  @relation(fields: [commitHash], references: [hash], onDelete: SetNull)

  @@index([testCaseId, executedAt])
  @@index([storyId])
  @@index([commitHash])
  @@index([status])
  @@map("test_executions")
}

// ============================================================================
// AGENTS, FRAMEWORKS, RUNS
// ============================================================================

model Agent {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId String?  @map("project_id") @db.Uuid
  name      String
  role      String
  config    Json // system prompt, tools, limits
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs    Run[]

  @@index([projectId, active])
  @@map("agents")
}

model AgentFramework {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId   String?  @map("project_id") @db.Uuid
  name        String
  description String?
  config      Json // composition of agents, routing rules
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stories Story[]
  runs    Run[]

  @@index([projectId, active])
  @@map("agent_frameworks")
}

model Run {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId    String    @map("project_id") @db.Uuid
  storyId      String?   @map("story_id") @db.Uuid
  subtaskId    String?   @map("subtask_id") @db.Uuid
  agentId      String?   @map("agent_id") @db.Uuid
  frameworkId  String?   @map("framework_id") @db.Uuid
  origin       RunOrigin
  tokensInput  Int       @default(0) @map("tokens_input")
  tokensOutput Int       @default(0) @map("tokens_output")
  startedAt    DateTime  @map("started_at") @db.Timestamptz
  finishedAt   DateTime? @map("finished_at") @db.Timestamptz
  success      Boolean   @default(true)
  errorType    String?   @map("error_type")
  iterations   Int       @default(1)
  metadata     Json? // flexible storage for additional data

  // Relations
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  story     Story?          @relation(fields: [storyId], references: [id], onDelete: SetNull)
  subtask   Subtask?        @relation(fields: [subtaskId], references: [id], onDelete: SetNull)
  agent     Agent?          @relation(fields: [agentId], references: [id], onDelete: SetNull)
  framework AgentFramework? @relation(fields: [frameworkId], references: [id], onDelete: SetNull)

  @@index([projectId, startedAt])
  @@index([storyId])
  @@index([frameworkId, success])
  @@map("runs")
}

// ============================================================================
// AGENT WORKFLOW MVP - GENERIC COMPONENT + COORDINATOR PATTERN
// ============================================================================

// Component - Generic building block configured via 3 instruction sets
model Component {
  id          String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId   String  @map("project_id") @db.Uuid
  name        String
  description String?

  // The core: 3 instruction sets
  inputInstructions     String @map("input_instructions") @db.Text
  operationInstructions String @map("operation_instructions") @db.Text
  outputInstructions    String @map("output_instructions") @db.Text

  // Execution configuration
  config        Json // { modelId, temperature, maxInputTokens, maxOutputTokens, timeout, maxRetries, costLimit }
  tools         String[] // MCP tool names this component can use
  subtaskConfig Json?    @map("subtask_config") // { createSubtask, layer, assignee }
  onFailure     String   @default("stop") @map("on_failure") // stop, skip, retry, pause

  // Metadata
  tags      String[]
  active    Boolean  @default(true)
  version   String   @default("v1.0")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ST-160: Native Subagent Support
  executionType     String @default("custom") @map("execution_type")
  // Values: "custom" | "native_explore" | "native_plan" | "native_general"
  nativeAgentConfig Json?  @map("native_agent_config")
  // For native types: { questionBehavior, maxQuestions, allowedTools, etc. }

  // Versioning fields (ST-58)
  versionMajor         Int       @default(1) @map("version_major")
  versionMinor         Int       @default(0) @map("version_minor")
  parentId             String?   @map("parent_id") @db.Uuid
  instructionsChecksum String?   @map("instructions_checksum")
  configChecksum       String?   @map("config_checksum")
  isDeprecated         Boolean   @default(false) @map("is_deprecated")
  deprecatedAt         DateTime? @map("deprecated_at")
  changeDescription    String?   @map("change_description")
  createdFromVersion   String?   @map("created_from_version")

  // Relations
  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  componentRuns    ComponentRun[]
  defects          DefectNew[]
  parent           Component?      @relation("ComponentVersions", fields: [parentId], references: [id], onDelete: SetNull)
  children         Component[]     @relation("ComponentVersions")
  workflowStates   WorkflowState[] // ST-143: States that use this component
  createdArtifacts Artifact[]      // ST-151: Artifacts created by this component
  createdArtifactVersions ArtifactVersion[] // ST-214: Artifact versions created by this component

  @@index([projectId])
  @@index([projectId, active])
  @@index([tags])
  @@index([parentId])
  @@index([projectId, active, versionMajor])
  @@index([versionMajor, versionMinor])
  @@map("components")
}

// CoordinatorAgent - DEPRECATED: Coordinators are now stored as Components with tags=['coordinator']
// This model is kept for reference but the table has been dropped.
// Relations updated to point to Component model instead.

// Workflow - Links states/agents + trigger configuration
// ST-164: coordinatorId removed - coordinators are deprecated, states define execution order
model Workflow {
  id          String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId   String  @map("project_id") @db.Uuid
  name        String
  description String?
  version     String  @default("v1.0")

  // Trigger configuration
  triggerConfig Json @map("trigger_config") // { type, filters, notifications }

  // Component assignments (ST-90)
  componentAssignments Json @default("[]") @map("component_assignments") // Array of { componentName, componentId, versionId, version, versionMajor, versionMinor }

  // Metadata (ST-103)
  metadata Json? @default("{}") // Stores autoDiff for version history and other workflow metadata

  // Settings
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Versioning fields (ST-58)
  versionMajor         Int       @default(1) @map("version_major")
  versionMinor         Int       @default(0) @map("version_minor")
  parentId             String?   @map("parent_id") @db.Uuid
  instructionsChecksum String?   @map("instructions_checksum")
  configChecksum       String?   @map("config_checksum")
  isDeprecated         Boolean   @default(false) @map("is_deprecated")
  deprecatedAt         DateTime? @map("deprecated_at")
  changeDescription    String?   @map("change_description")
  createdFromVersion   String?   @map("created_from_version")

  // Relations
  project             Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stories             Story[]
  workflowRuns        WorkflowRun[]
  activeWorkflows     ActiveWorkflow[]
  parent              Workflow?            @relation("WorkflowVersions", fields: [parentId], references: [id], onDelete: SetNull)
  children            Workflow[]           @relation("WorkflowVersions")
  states              WorkflowState[]      // ST-143: Workflow states for story runner
  artifactDefinitions ArtifactDefinition[] // ST-151: Artifact definitions for this workflow

  @@index([projectId])
  @@index([projectId, active])
  @@index([parentId])
  @@index([projectId, active, versionMajor])
  @@index([versionMajor, versionMinor])
  @@map("workflows")
}

// WorkflowRun - Execution of a workflow
// ST-164: coordinatorId removed - coordinators are deprecated
model WorkflowRun {
  id         String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId  String  @map("project_id") @db.Uuid
  workflowId String  @map("workflow_id") @db.Uuid
  storyId    String? @map("story_id") @db.Uuid
  epicId     String? @map("epic_id") @db.Uuid

  // Trigger info
  triggeredBy String? @map("triggered_by") // User ID or "system"
  triggerType String? @map("trigger_type") // manual, story_assigned, etc.

  // Status
  status RunStatus @default(pending)

  // ST-143: Story Runner state tracking
  currentStateId  String?   @map("current_state_id") @db.Uuid // Which state is currently executing
  runnerSessionId String?   @map("runner_session_id") // Runner's Claude Code session ID
  isPaused        Boolean   @default(false) @map("is_paused") // Whether runner is paused
  pausedAt        DateTime? @map("paused_at") // When paused
  pauseReason     String?   @map("pause_reason") // Why paused (breakpoint, error, approval needed)

  // ST-150: Remote agent execution tracking
  executingAgentId    String?   @map("executing_agent_id") @db.Uuid // RemoteAgent ID if executing on laptop
  agentDisconnectedAt DateTime? @map("agent_disconnected_at") // When remote agent disconnected (for pause-on-offline)

  // Timing
  startedAt       DateTime  @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  durationSeconds Int?      @map("duration_seconds")

  // Aggregated metrics
  totalTokensInput  Int?   @map("total_tokens_input")
  totalTokensOutput Int?   @map("total_tokens_output")
  totalTokens       Int?   @map("total_tokens")
  totalLocGenerated Int?   @map("total_loc_generated")
  totalTestsAdded   Int?   @map("total_tests_added")
  estimatedCost     Float? @map("estimated_cost")

  // Iteration metrics (NEW)
  totalUserPrompts       Int?   @map("total_user_prompts")
  totalIterations        Int?   @map("total_iterations")
  totalInterventions     Int?   @map("total_interventions")
  avgPromptsPerComponent Float? @map("avg_prompts_per_component")

  // ST-147: Runner Session Telemetry
  runnerTranscriptPath String? @map("runner_transcript_path") // Path to runner transcript JSONL
  runnerTokensInput    Int?    @default(0) @map("runner_tokens_input")
  runnerTokensOutput   Int?    @default(0) @map("runner_tokens_output")
  totalRunnerTokens    Int?    @default(0) @map("total_runner_tokens")

  // ST-172: Hook-based transcript tracking
  masterTranscriptPaths    String[] @default([]) @map("master_transcript_paths") // All master session transcripts (including post-compact)
  // @deprecated DO NOT USE - Data is stored in metadata.spawnedAgentTranscripts instead!
  // This field exists but is NEVER populated. Always read from metadata.spawnedAgentTranscripts.
  // TODO: Remove this field in a future migration once all code references are cleaned up.
  spawnedAgentTranscripts  Json?    @map("spawned_agent_transcripts") // DEPRECATED - see metadata.spawnedAgentTranscripts

  // ST-147: Turn Tracking (distinguish all turns vs manual input)
  totalTurns         Int? @default(0) @map("total_turns") // All human messages in transcripts
  totalManualPrompts Int? @default(0) @map("total_manual_prompts") // Actual user-typed input only

  // ST-147: Resume Context
  resumeSummary      String?   @map("resume_summary") @db.Text // AI-generated summary for resume
  resumeGeneratedAt  DateTime? @map("resume_generated_at")
  decisionHistory    Json?     @map("decision_history") // Array of DecisionRecord[]
  checkpointData     Json?     @map("checkpoint_data") // RunnerCheckpoint structure
  lastCheckpointAt   DateTime? @map("last_checkpoint_at")

  // Coordinator execution
  coordinatorDecisions Json?   @map("coordinator_decisions") // Array of decisions made
  coordinatorMetrics   Json?   @map("coordinator_metrics") // Coordinator runtime, cost, etc.
  errorMessage         String? @map("error_message")

  // Metadata
  metadata Json? // Execution plan, etc.

  // Relations
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workflow      Workflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  story         Story?         @relation(fields: [storyId], references: [id], onDelete: SetNull)
  epic          Epic?          @relation(fields: [epicId], references: [id], onDelete: SetNull)
  componentRuns ComponentRun[]
  defects       DefectNew[]
  otelEvents    OtelEvent[]
  // ST-143: Story Runner relations
  currentState  WorkflowState?   @relation("CurrentState", fields: [currentStateId], references: [id], onDelete: SetNull)
  breakpoints   RunnerBreakpoint[]
  // ST-150: Agent stream events
  agentStreamEvents AgentStreamEvent[]
  // ST-151: Artifacts for this workflow run
  artifacts     Artifact[]
  // ST-148: Approval gates
  approvalRequests ApprovalRequest[]
  // ST-160: Agent questions
  agentQuestions   AgentQuestion[]
  // ST-170: Transcript storage
  transcripts            Transcript[]
  unassignedTranscripts  UnassignedTranscript[]
  // ST-214: Artifact version history
  artifactVersions       ArtifactVersion[]
  artifactsLastUpdated   Artifact[]        @relation("ArtifactLastUpdatedRun")

  @@index([projectId])
  @@index([workflowId])
  @@index([storyId])
  @@index([startedAt])
  @@index([status])
  @@index([currentStateId]) // ST-143: Index for state queries
  @@index([isPaused]) // ST-143: Index for paused runs
  @@index([totalTurns]) // ST-147: Index for analytics
  @@index([totalManualPrompts]) // ST-147: Index for analytics
  @@map("workflow_runs")
}

// ComponentRun - Individual component execution within workflow
model ComponentRun {
  id            String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workflowRunId String @map("workflow_run_id") @db.Uuid
  componentId   String @map("component_id") @db.Uuid

  executionOrder Int? @map("execution_order") // 1, 2, 3, ... (order within workflow)

  // Status
  status  RunStatus @default(pending)
  success Boolean   @default(false)

  // Input/Output
  inputData     Json?   @map("input_data") // Data received
  outputData    Json?   @map("output_data") // Data produced
  output        String? @db.Text // Output text
  // outputSummary removed in ST-203 - use componentSummary instead (JSON with structured format)

  // Universal metrics
  tokensInput     Int?   @default(0) @map("tokens_input")
  tokensOutput    Int?   @default(0) @map("tokens_output")
  totalTokens     Int?   @map("total_tokens")
  durationSeconds Int?   @map("duration_seconds")
  cost            Float? @default(0)
  iterations      Int?   @default(1)
  locGenerated    Int?   @map("loc_generated") // Lines of code (if applicable)
  testsAdded      Int?   @map("tests_added") // Number of tests added (if applicable)

  // Code changes
  filesModified String[] @default([]) @map("files_modified")
  commits       String[] @default([])

  // Efficiency metrics (calculated)
  tokensPerLoc    Float? @map("tokens_per_loc")
  locPerPrompt    Float? @map("loc_per_prompt")
  runtimePerLoc   Float? @map("runtime_per_loc")
  runtimePerToken Float? @map("runtime_per_token")

  // Iteration tracking (NEW)
  userPrompts        Int?  @default(0) @map("user_prompts")
  systemIterations   Int?  @default(1) @map("system_iterations")
  humanInterventions Int?  @default(0) @map("human_interventions")
  iterationLog       Json? @map("iteration_log") // Array of iterations with timestamps
  toolCalls          Int?  @default(0) @map("tool_calls") // ST-57: Tool calls count (for orchestrator and components)

  // ST-27 Comprehensive Metrics - Session Tracking
  sessionId String? @map("session_id") // Claude Code session ID (transcript-based metrics)

  // ST-110: Token Breakdown from /context command
  tokensSystemPrompt Int? @default(0) @map("tokens_system_prompt") // System prompt tokens
  tokensSystemTools  Int? @default(0) @map("tokens_system_tools") // System tools tokens
  tokensMcpTools     Int? @default(0) @map("tokens_mcp_tools") // MCP tools tokens
  tokensMemoryFiles  Int? @default(0) @map("tokens_memory_files") // Memory files tokens
  tokensMessages     Int? @default(0) @map("tokens_messages") // User/assistant messages tokens

  // ST-242: Cache token metrics (restored - needed for telemetry)
  tokensCacheCreation Int? @default(0) @map("tokens_cache_creation") // Cache creation tokens
  tokensCacheRead     Int? @default(0) @map("tokens_cache_read") // Cache read tokens

  // ST-27 Comprehensive Metrics - Code Impact Metrics
  linesAdded       Int?   @default(0) @map("lines_added")
  linesDeleted     Int?   @default(0) @map("lines_deleted")
  linesModified    Int?   @default(0) @map("lines_modified")
  complexityBefore Float? @map("complexity_before") // Cyclomatic complexity
  complexityAfter  Float? @map("complexity_after")
  coverageBefore   Float? @map("coverage_before") // Test coverage %
  coverageAfter    Float? @map("coverage_after")

  // ST-27 Comprehensive Metrics - Quality Metrics
  errorRate     Float? @map("error_rate") // Failed tools / total tools
  successRate   Float? @map("success_rate") // Successful completions
  toolBreakdown Json?  @map("tool_breakdown") // Tool-level stats {toolName: {calls, errors, avgDuration}}

  // ST-27 Comprehensive Metrics - Agent Behavior
  contextSwitches  Int? @default(0) @map("context_switches") // File/domain changes
  explorationDepth Int? @default(0) @map("exploration_depth") // Files analyzed before implementing

  // ST-27 Comprehensive Metrics - Cost & Performance
  costBreakdown    Json?   @map("cost_breakdown") // {input: $, output: $, cache: $}
  modelId          String? @map("model_id") // Model used (e.g., claude-3-opus-20240229)
  temperature      Float? // Model temperature setting
  maxTokens        Int?    @map("max_tokens") // Max tokens configuration
  stopReason       String? @map("stop_reason") // end_turn, max_tokens, tool_use, error
  timeToFirstToken Float?  @map("time_to_first_token") // Seconds
  tokensPerSecond  Float?  @map("tokens_per_second") // Throughput

  // Execution details
  startedAt  DateTime  @map("started_at")
  finishedAt DateTime? @map("finished_at")
  retryCount Int?      @default(0) @map("retry_count")

  // Error tracking
  errorType    String? @map("error_type")
  errorMessage String? @map("error_message")

  // Metadata
  metadata Json? // Logs, intermediate results, etc.

  // Artifacts (S3 storage)
  artifacts Json? // Array of { name, s3Key, type, size }

  // ST-150: Remote Execution Tracking
  remoteJobId String? @map("remote_job_id") @db.Uuid // Link to RemoteJob if executed remotely
  executedOn  String? @map("executed_on") // "kvm_server" | "laptop:hostname"

  // ST-147: Turn Tracking (per-component level)
  totalTurns    Int? @default(0) @map("total_turns") // All conversation turns
  manualPrompts Int? @default(0) @map("manual_prompts") // Actual user input only
  autoContinues Int? @default(0) @map("auto_continues") // Auto-continue count

  // ST-147: Transcript & Summary
  transcriptPath   String? @map("transcript_path") // Path to agent transcript JSONL
  claudeAgentId    String? @map("claude_agent_id") // Claude Code agent ID (8-char hex) - filename is agent-{id}.jsonl
  componentSummary String? @map("component_summary") @db.Text // AI summary of what agent did

  // Relations
  workflowRun        WorkflowRun        @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  component          Component          @relation(fields: [componentId], references: [id], onDelete: Restrict)
  subtasks           Subtask[]
  otelEvents         OtelEvent[]
  agentStreamEvents  AgentStreamEvent[] // ST-150: Streaming events from remote execution
  transcripts        Transcript[]       // ST-170: Transcript storage

  @@index([workflowRunId])
  @@index([componentId])
  @@index([startedAt])
  @@index([status])
  @@index([remoteJobId]) // ST-150: Index for remote job lookups
  @@index([totalTurns]) // ST-147: Index for analytics
  @@map("component_runs")
}

// ST-27: OtelEvent - DEPRECATED: OpenTelemetry event tracking (no longer used)
// NOTE: This table and model still exist for backward compatibility but are not actively used.
// Metrics are now collected via transcript analysis instead of OTEL events.
model OtelEvent {
  id             String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId      String  @map("project_id") @db.Uuid
  sessionId      String  @map("session_id") // Claude Code session identifier
  workflowRunId  String? @map("workflow_run_id") @db.Uuid // Extracted from metadata
  componentRunId String? @map("component_run_id") @db.Uuid // Linked via session mapping

  // Event data
  timestamp DateTime // When event occurred
  eventType String   @map("event_type") // claude_code.api_request, claude_code.tool_use, etc.
  eventName String?  @map("event_name") // Human-readable event name

  // General metadata
  metadata   Json? // Event metadata (tokens, model, etc.)
  attributes Json? // Event attributes

  // Tool usage specific fields
  toolName       String?  @map("tool_name") // Read, Write, Edit, Bash, MCP tool name
  toolParameters Json?    @map("tool_parameters") // Tool input parameters
  toolDuration   Float?   @map("tool_duration") // Tool execution time in seconds
  toolSuccess    Boolean? @map("tool_success") // Whether tool succeeded
  toolError      String?  @map("tool_error") // Error message if failed

  // Processed flags
  processed    Boolean   @default(false) // Whether event has been processed for aggregation
  aggregatedAt DateTime? @map("aggregated_at") // When metrics were aggregated

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workflowRun  WorkflowRun?  @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  componentRun ComponentRun? @relation(fields: [componentRunId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@index([workflowRunId, componentRunId])
  @@index([projectId, eventType, timestamp])
  @@index([processed, aggregatedAt])
  @@map("otel_events")
}

// DefectNew - Enhanced defect tracking with origin story
model DefectNew {
  id          String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId   String         @map("project_id") @db.Uuid
  key         String         @unique // BUG-123
  title       String
  description String
  severity    DefectSeverity

  // Story relationships
  foundInStoryId      String? @map("found_in_story_id") @db.Uuid
  introducedByStoryId String? @map("introduced_by_story_id") @db.Uuid
  confirmedByUserId   String? @map("confirmed_by_user_id") @db.Uuid

  // Workflow tracking
  introducedByWorkflowRunId String? @map("introduced_by_workflow_run_id") @db.Uuid
  introducedByComponentId   String? @map("introduced_by_component_id") @db.Uuid

  // Status
  status      String // open, confirmed, fixed, closed
  confirmedAt DateTime? @map("confirmed_at")
  fixedAt     DateTime? @map("fixed_at")

  // Root cause analysis
  rootCause     String?  @map("root_cause")
  affectedFiles String[] @map("affected_files")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  project                 Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
