// ============================================================================
// PRODUCTION DEPLOYMENT SAFETY (Epic EP-7 - ST-84)
// ============================================================================

// DeploymentLock - Production deployment locking (only 1 deploy at a time)
model DeploymentLock {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  storyId    String?   @map("story_id") @db.Uuid
  prNumber   Int?      @map("pr_number")
  reason     String
  lockedBy   String    @map("locked_by") // user/agent identifier
  lockedAt   DateTime  @default(now()) @map("locked_at")
  expiresAt  DateTime  @map("expires_at")
  releasedAt DateTime? @map("released_at")
  active     Boolean   @default(true)
  metadata   Json?     // deployment context (commitHash, branch, etc.)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  // Relations
  story Story? @relation(fields: [storyId], references: [id], onDelete: SetNull)

  @@index([active, expiresAt])
  @@index([storyId])
  @@map("deployment_locks")
}

// DeploymentLog - Production deployment audit log
model DeploymentLog {
  id             String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  storyId        String?          @map("story_id") @db.Uuid
  prNumber       Int?             @map("pr_number")
  deploymentId   String?          @map("deployment_id") @db.Uuid // FK to DeploymentLock
  status         DeploymentStatus @default(pending)
  environment    String           // 'production', 'staging'
  branch         String?
  commitHash     String?          @map("commit_hash")
  approvedBy     String?          @map("approved_by") // GitHub username or manual approver
  approvedAt     DateTime?        @map("approved_at")
  deployedBy     String?          @map("deployed_by") // Agent/user identifier
  deployedAt     DateTime?        @map("deployed_at")
  completedAt    DateTime?        @map("completed_at")
  errorMessage   String?          @map("error_message") @db.Text
  logs           String?          @db.Text // Full Docker build/deploy logs
  metadata       Json?            // Deployment details

  // ST-84: Approval method tracking (PR vs manual)
  approvalMethod String?          @map("approval_method") // 'PR' | 'MANUAL'

  // ST-268: Async deployment tracking
  currentPhase       String?   @map("current_phase")
  progress           Json?
  childProcessPid    Int?      @map("child_process_pid")
  lastHeartbeat      DateTime? @map("last_heartbeat")

  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  // Relations
  story Story? @relation(fields: [storyId], references: [id], onDelete: SetNull)

  // Indexes for audit queries
  @@index([status, createdAt])
  @@index([storyId, status])
  @@index([prNumber])
  @@index([environment, status])
  @@index([createdAt]) // Time-series queries
  @@map("deployment_logs")
}

enum DeploymentStatus {
  pending // Awaiting approval or validation
  approved // PR approved, awaiting deployment execution
  queued // ST-268: Queued for async execution
  deploying // Deployment in progress
  deployed // Successfully deployed
  failed // Deployment failed (before or during execution)
  rolled_back // Deployment rolled back after failure
}

enum BreakpointPosition {
  before // Pause before state execution
  after // Pause after state execution
}

// ============================================================================
// ST-148: APPROVAL GATES - HUMAN-IN-THE-LOOP
// ============================================================================

enum ApprovalStatus {
  pending   // Waiting for human decision
  approved  // Approved, continue execution
  rejected  // Rejected, workflow cancelled or paused
  cancelled // Request cancelled (workflow cancelled)
}

enum ApprovalResolution {
  approved  // Human approved the state output
  rejected  // Human rejected the state output
  cancelled // Request was cancelled
}

enum ReExecutionMode {
  feedback_injection // Re-run state with feedback injected into prompt
  artifact_edit      // Continue after manual artifact edits
  both               // Both feedback injection and artifact edits
  none               // Just continue (approved without changes)
}

// ServiceDeploymentState - Track last deployed commit per service (ST-115 Build Optimization)
// Used for intelligent change detection to skip rebuilds when service hasn't changed
model ServiceDeploymentState {
  id                 String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  service            String   @unique // 'backend' | 'frontend'
  lastDeployedCommit String   @map("last_deployed_commit") // Git commit hash (40 char SHA)
  lastDeployedAt     DateTime @map("last_deployed_at")
  filesChanged       String[] @map("files_changed") // List of files in last deployment
  metadata           Json?    // Additional deployment info (build duration, etc.)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([service])
  @@index([lastDeployedAt])
  @@map("service_deployment_states")
}

// ============================================================================
// DISK SPACE MONITORING (Epic EP-7 - ST-54)
// ============================================================================

enum AlertType {
  warning // Disk space below warning threshold (e.g., < 5GB)
  critical // Disk space critically low (e.g., < 2GB)
}

// DiskUsageAlert - Track disk space threshold breach events
model DiskUsageAlert {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  alertType        AlertType @map("alert_type")
  thresholdGB      Int       @map("threshold_gb")
  availableSpaceGB Decimal   @map("available_space_gb") @db.Decimal(10, 2)
  usedSpaceGB      Decimal   @map("used_space_gb") @db.Decimal(10, 2)
  totalSpaceGB     Decimal   @map("total_space_gb") @db.Decimal(10, 2)
  percentUsed      Decimal   @map("percent_used") @db.Decimal(5, 2)
  worktreeCount    Int       @map("worktree_count")
  stalledCount     Int       @map("stalled_count")
  message          String    @db.Text
  notificationSent Boolean   @default(false) @map("notification_sent")
  notifiedAt       DateTime? @map("notified_at")

  @@index([createdAt(sort: Desc)])
  @@index([alertType, createdAt])
  @@map("disk_usage_alerts")
}

// DiskUsageReport - Weekly disk usage summary reports
model DiskUsageReport {
  id                String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at")
  reportDate        DateTime @map("report_date") // Monday of the week
  reportPeriodStart DateTime @map("report_period_start")
  reportPeriodEnd   DateTime @map("report_period_end")

  // Disk metrics
  totalSpaceGB     Decimal @map("total_space_gb") @db.Decimal(10, 2)
  usedSpaceGB      Decimal @map("used_space_gb") @db.Decimal(10, 2)
  availableSpaceGB Decimal @map("available_space_gb") @db.Decimal(10, 2)
  percentUsed      Decimal @map("percent_used") @db.Decimal(5, 2)

  // Worktree metrics
  totalWorktrees       Int     @map("total_worktrees")
  activeWorktrees      Int     @map("active_worktrees")
  stalledWorktrees     Int     @map("stalled_worktrees")
  totalWorktreeUsageMB Int     @map("total_worktree_usage_mb")
  avgWorktreeUsageMB   Decimal @map("avg_worktree_usage_mb") @db.Decimal(10, 2)

  // Breakdown (JSON)
  largestWorktrees     Json? @map("largest_worktrees") // Top 10: [{storyKey, size, age}, ...]
  stalledWorktreesList Json? @map("stalled_worktrees_list") // [{storyKey, branch, size, lastUpdated}, ...]

  // Trends
  weekOverWeekChangeGB      Decimal? @map("week_over_week_change_gb") @db.Decimal(10, 2)
  weekOverWeekChangePercent Decimal? @map("week_over_week_change_percent") @db.Decimal(5, 2)

  // Report metadata
  reportHtml  String?   @db.Text // Rendered HTML report
  emailSent   Boolean   @default(false) @map("email_sent")
  emailSentAt DateTime? @map("email_sent_at")

  @@index([reportDate(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("disk_usage_reports")
}

// ============================================================================
// STORY RUNNER - STATE MACHINE (ST-143)
// ============================================================================

// WorkflowState - Defines execution states within a workflow
// Each state represents a phase (analysis, architecture, implementation) with its own agent config
model WorkflowState {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workflowId String   @map("workflow_id") @db.Uuid
  name       String   // State name: "analysis", "architecture", "implementation", etc.
  order      Int      // Execution order (1, 2, 3, ...)

  // Agent Configuration - which component executes in this state
  componentId String? @map("component_id") @db.Uuid

  // Pre/Post Execution Instructions (run by story runner, not the agent)
  preExecutionInstructions  String? @map("pre_execution_instructions") @db.Text
  postExecutionInstructions String? @map("post_execution_instructions") @db.Text

  // Configuration
  requiresApproval Boolean @default(false) @map("requires_approval") // Human-in-the-loop gate
  mandatory        Boolean @default(true) // Must complete to proceed to next state

  // ST-150: Remote Agent Execution Configuration
  runLocation     String @default("local") @map("run_location") // "local" | "laptop"
  offlineFallback String @default("pause") @map("offline_fallback") // "pause" | "skip" | "fail"

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  workflow              Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  component             Component?         @relation(fields: [componentId], references: [id], onDelete: SetNull)
  workflowRunsAtState   WorkflowRun[]      @relation("CurrentState")
  breakpointsAtState    RunnerBreakpoint[]
  artifactAccess        ArtifactAccess[]   // ST-151: Access rules for this state
  approvalRequests      ApprovalRequest[]  // ST-148: Approval requests for this state
  agentQuestions        AgentQuestion[]    // ST-160: Questions asked during this state

  @@unique([workflowId, name])
  @@unique([workflowId, order])
  @@index([workflowId, order])
  @@map("workflow_states")
}

// RunnerBreakpoint - Debugging support for story runner
// Allows pausing execution before or after specific states
model RunnerBreakpoint {
  id            String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workflowRunId String             @map("workflow_run_id") @db.Uuid
  stateId       String             @map("state_id") @db.Uuid
  position      BreakpointPosition // "before" | "after"
  isActive      Boolean            @default(true) @map("is_active")
  hitAt         DateTime?          @map("hit_at") // When breakpoint was triggered

  // ST-146: Conditional breakpoints and step mode
  condition   Json?   @db.JsonB // Optional JSON condition for conditional breakpoints
  isTemporary Boolean @default(false) @map("is_temporary") // For step mode temp breakpoints

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  workflowRun WorkflowRun   @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  state       WorkflowState @relation(fields: [stateId], references: [id], onDelete: Cascade)

  @@unique([workflowRunId, stateId, position])
  @@index([workflowRunId, isActive])
  @@map("runner_breakpoints")
}

// ApprovalRequest - Human-in-the-loop approval gates for story runner
// Created when a state with requiresApproval=true completes execution
model ApprovalRequest {
  id            String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workflowRunId String @map("workflow_run_id") @db.Uuid
  stateId       String @map("state_id") @db.Uuid
  projectId     String @map("project_id") @db.Uuid

  // Request metadata
  stateName   String   @map("state_name")
  stateOrder  Int      @map("state_order")
  requestedBy String   @map("requested_by")
  requestedAt DateTime @default(now()) @map("requested_at")

  // Status tracking
  status ApprovalStatus @default(pending)

  // Context for reviewer
  contextSummary String?  @map("context_summary") @db.Text
  artifactKeys   String[] @default([]) @map("artifact_keys")
  tokensUsed     Int      @default(0) @map("tokens_used")

  // Resolution
  resolvedAt DateTime?          @map("resolved_at")
  resolvedBy String?            @map("resolved_by")
  resolution ApprovalResolution?
  reason     String?            @db.Text

  // Re-execution configuration (for rerun action)
  reExecutionMode ReExecutionMode? @map("re_execution_mode")
  feedback        String?          @db.Text // Instructions for re-run
  editedArtifacts String[]         @default([]) @map("edited_artifacts")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  workflowRun WorkflowRun   @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  state       WorkflowState @relation(fields: [stateId], references: [id], onDelete: Cascade)
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([workflowRunId, stateId])
  @@index([workflowRunId, status])
  @@index([projectId, status])
  @@index([status, requestedAt])
  @@map("approval_requests")
}

// ============================================================================
// ST-160: AGENT QUESTION HANDLING - INTERACTIVE CLI QUESTIONS
// ============================================================================

// AgentQuestion - Track questions asked by Claude CLI agents during execution
// Questions are detected from text patterns in stream-json output
// Answers are injected via --resume <sessionId> "answer"
model AgentQuestion {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workflowRunId  String   @map("workflow_run_id") @db.Uuid
  stateId        String   @map("state_id") @db.Uuid
  componentRunId String?  @map("component_run_id") @db.Uuid

  // Session tracking (CRITICAL for --resume)
  sessionId      String   @map("session_id") // CLI session ID from init message - REQUIRED for resume

  // Question details (detected from text output)
  questionText   String   @map("question_text") @db.Text // Full text containing the question

  // Status
  status         AgentQuestionStatus @default(pending)
  answer         String?  @db.Text // User's answer text (injected via --resume)
  answeredBy     String?  @map("answered_by")
  answeredAt     DateTime? @map("answered_at")

  // Session handoff capability
  canHandoff     Boolean  @default(true) @map("can_handoff")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  workflowRun    WorkflowRun   @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  state          WorkflowState @relation(fields: [stateId], references: [id], onDelete: Cascade)

  @@index([workflowRunId, status])
  @@index([sessionId])
  @@index([status, createdAt])
  @@map("agent_questions")
}

enum AgentQuestionStatus {
  pending   // Waiting for user answer
  answered  // User provided answer, will be injected via --resume
  skipped   // User skipped the question (timeout or manual skip)
  cancelled // Question cancelled (workflow cancelled)
}

// ============================================================================
// REMOTE EXECUTION AGENT (ST-133)
// ============================================================================

// RemoteAgent - Track connected remote agents (laptop/local machines)
model RemoteAgent {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  hostname     String    @unique
  socketId     String?   @map("socket_id")
  status       String    @default("offline") // online, offline
  lastSeenAt   DateTime? @map("last_seen_at")
  capabilities String[]  // ['parse-transcript', 'analyze-story-transcripts', 'claude-code', 'git-execute']
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // ST-150: Claude Code execution support
  claudeCodeAvailable Boolean   @default(false) @map("claude_code_available") // Whether Claude Code CLI is available
  claudeCodeVersion   String?   @map("claude_code_version") // Version of Claude Code CLI
  currentExecutionId  String?   @map("current_execution_id") @db.Uuid // Currently executing job ID

  // ST-158: Agent configuration (projectPath, worktreeRoot for MCP orchestration)
  config              Json      @default("{}") // { projectPath: string, worktreeRoot: string }

  @@index([status, claudeCodeAvailable]) // ST-150: Find online agents with Claude Code
  @@map("remote_agents")
}

// RemoteJob - Track remote script execution jobs
model RemoteJob {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  script      String
  params      Json
  status      String    @default("pending") // pending, running, completed, failed, timeout, waiting_reconnect
  result      Json?
  error       String?
  agentId     String?   @map("agent_id")
  requestedBy String?   @map("requested_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  // ST-150: Claude Code execution fields
  jobType            String?   @map("job_type") // 'script' | 'claude-agent'
  componentRunId     String?   @map("component_run_id") @db.Uuid // Link to ComponentRun for Claude jobs
  workflowRunId      String?   @map("workflow_run_id") @db.Uuid // Link to WorkflowRun
  lastHeartbeatAt    DateTime? @map("last_heartbeat_at") // For tiered heartbeat monitoring
  disconnectedAt     DateTime? @map("disconnected_at") // When agent disconnected during execution
  reconnectExpiresAt DateTime? @map("reconnect_expires_at") // Grace period expiration (15 min from disconnect)

  @@index([status, createdAt])
  @@index([componentRunId]) // ST-150: Find job by component run
  @@index([workflowRunId, status]) // ST-150: Find running jobs for workflow
  @@index([status, reconnectExpiresAt]) // ST-150: Orphan detection query
  @@map("remote_jobs")
}

// ============================================================================
// ST-151: ARTIFACT MANAGEMENT FOR STORY RUNNER
// ============================================================================

// ArtifactDefinition - Defines what artifacts a workflow can produce/consume
model ArtifactDefinition {
  id          String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workflowId  String  @map("workflow_id") @db.Uuid

  name        String  // "Architecture Document"
  key         String  // Unique key like "ARCH_DOC"
  description String?
  type        String  // "markdown" | "json" | "code" | "report" | "image" | "other"
  schema      Json?   // JSON Schema for validation (optional)
  isMandatory Boolean @default(false) @map("is_mandatory")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  workflow    Workflow         @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  artifacts   Artifact[]
  accessRules ArtifactAccess[]

  @@unique([workflowId, key])
  @@index([workflowId])
  @@map("artifact_definitions")
}

// Artifact - Story-scoped artifact with version history (ST-214)
model Artifact {
  id            String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  definitionId  String @map("definition_id") @db.Uuid
  storyId       String @map("story_id") @db.Uuid
  workflowRunId String? @map("workflow_run_id") @db.Uuid

  content        String  @db.Text // Actual content or S3 URL
  contentPreview String? @map("content_preview") @db.VarChar(500) // First 500 chars for token-efficient queries
  contentHash    String? @map("content_hash") @db.VarChar(64) // SHA256 for change detection
  contentType    String  @map("content_type") // MIME type
  size           Int     @default(0)
  currentVersion Int     @default(1) @map("current_version") // Latest version number
  lastUpdatedRunId String? @map("last_updated_run_id") @db.Uuid // WorkflowRun that last updated this

  // Provenance
  createdByComponentId String? @map("created_by_component_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  definition         ArtifactDefinition  @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  story              Story               @relation(fields: [storyId], references: [id], onDelete: Cascade)
  workflowRun        WorkflowRun?        @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  lastUpdatedRun     WorkflowRun?        @relation("ArtifactLastUpdatedRun", fields: [lastUpdatedRunId], references: [id], onDelete: SetNull)
  createdByComponent Component?          @relation(fields: [createdByComponentId], references: [id], onDelete: SetNull)
  versions           ArtifactVersion[]

  @@unique([definitionId, storyId])
  @@index([storyId])
  @@index([workflowRunId])
  @@index([definitionId, storyId])
  @@map("artifacts")
}

// ArtifactVersion - Version history for artifacts (ST-214)
model ArtifactVersion {
  id              String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  artifactId      String @map("artifact_id") @db.Uuid
  version         Int
  workflowRunId   String? @map("workflow_run_id") @db.Uuid

  content         String @db.Text
  contentHash     String @map("content_hash") @db.VarChar(64)
  contentType     String @map("content_type")
  size            Int    @default(0)

  createdByComponentId String? @map("created_by_component_id") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at")

  artifact      Artifact     @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  workflowRun   WorkflowRun? @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  createdByComponent Component? @relation(fields: [createdByComponentId], references: [id], onDelete: SetNull)

  @@unique([artifactId, version])
  @@index([artifactId, version(sort: Desc)])
  @@index([workflowRunId])
  @@map("artifact_versions")
}

// ArtifactAccess - Controls which states can access which artifacts
model ArtifactAccess {
  id           String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  definitionId String @map("definition_id") @db.Uuid
  stateId      String @map("state_id") @db.Uuid

  accessType String @map("access_type") // "read" | "write" | "required"

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  definition ArtifactDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  state      WorkflowState      @relation(fields: [stateId], references: [id], onDelete: Cascade)

  @@unique([definitionId, stateId])
  @@index([stateId])
  @@map("artifact_access")
}

// ============================================================================
// ST-150: AGENT STREAM EVENTS (Real-time execution streaming)
// ============================================================================

// AgentStreamEvent - Stores streaming events from Claude Code agent execution
// Captures token updates, tool calls, tool results, and stream completion events
model AgentStreamEvent {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  componentRunId  String   @map("component_run_id") @db.Uuid
  workflowRunId   String   @map("workflow_run_id") @db.Uuid

  // Event data
  eventType       String   @map("event_type") // token_update, tool_call, tool_result, activity_change, stream_end
  sequenceNumber  Int      @map("sequence_number") // For ordering and replay
  timestamp       DateTime
  payload         Json // Event-specific data

  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  componentRun    ComponentRun @relation(fields: [componentRunId], references: [id], onDelete: Cascade)
  workflowRun     WorkflowRun  @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

  @@index([componentRunId, sequenceNumber])
  @@index([workflowRunId, eventType])
  @@index([componentRunId, eventType, timestamp]) // For filtering by event type
  @@map("agent_stream_events")
}

// ============================================================================
// ST-170: TRANSCRIPT STORAGE (File-Watching Daemon)
// ============================================================================

// Transcript - Stores completed transcript content for master sessions and spawned agents
// Replaces in-memory storage with persistent database records for better scalability
model Transcript {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  type           TranscriptType
  sessionId      String?         @map("session_id") // Claude session ID
  agentId        String?         @map("agent_id") // Agent ID (8-char hex) for agent transcripts
  workflowRunId  String?         @map("workflow_run_id") @db.Uuid
  componentRunId String?         @map("component_run_id") @db.Uuid

  content        String          @db.Text // Full JSONL transcript content
  contentSize    Int?            @map("content_size") // Size in bytes
  metrics        Json?           // Parsed metrics (ST-27): totalTokens, toolCallCount, duration, etc.

  uploadedAt     DateTime        @default(now()) @map("uploaded_at")
  createdAt      DateTime        @default(now()) @map("created_at")

  // Relations
  workflowRun    WorkflowRun?    @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  componentRun   ComponentRun?   @relation(fields: [componentRunId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([workflowRunId])
  @@index([componentRunId])
  @@index([type])
  @@index([uploadedAt])
  @@map("transcripts")
}

enum TranscriptType {
  MASTER  // Master orchestrator session transcript
  AGENT   // Spawned agent transcript

  @@map("transcript_type")
}

// UnassignedTranscript - Stores transcripts detected but not yet matched to a workflow
// When a workflow starts, we check this table for matching sessionId and associate them
model UnassignedTranscript {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  sessionId     String   @map("session_id") // Claude session ID from first line
  agentId       String?  @map("agent_id") // Agent ID if agent transcript, null if master session
  transcriptPath String  @map("transcript_path") // Full path to transcript file
  projectPath   String   @map("project_path") // Project path from agent

  // Metadata from first line
  type          String   // "file-history-snapshot", "user", "assistant", etc.
  cwd           String?  // Current working directory from transcript

  detectedAt    DateTime @default(now()) @map("detected_at")
  matchedAt     DateTime? @map("matched_at") // When matched to workflow
  workflowRunId String?  @map("workflow_run_id") @db.Uuid // Set when matched

  // Relations
  workflowRun   WorkflowRun? @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)

  @@index([sessionId]) // For fast lookup when workflow starts
  @@index([matchedAt]) // For finding unmatched transcripts
  @@index([workflowRunId])
  @@map("unassigned_transcripts")
}
