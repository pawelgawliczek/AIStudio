{
  "name": "@aistudio/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Vibe Studio Backend - NestJS REST API and MCP Server",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "test:cov": "jest --coverage --runInBand",
    "test:cov:summary": "jest --coverage --coverageReporters=text-summary --runInBand",
    "test:cov:html": "jest --coverage --coverageReporters=html,text-summary --runInBand && echo '\nCoverage report generated at: backend/coverage/index.html'",
    "test:cov:execution": "jest src/mcp/servers/execution --coverage --coverageReporters=text,html --runInBand",
    "test:diagnose": "jest --runInBand --detectOpenHandles --forceExit --testTimeout=30000",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:unit:report": "jest --testPathIgnorePatterns='integration|e2e' --json --outputFile=../test-results/jest-unit-results.json",
    "test:integration:report": "jest --testPathPattern='integration' --json --outputFile=../test-results/jest-integration-results.json",
    "test:all": "npm test && npm run test:e2e:ep8",
    "test:e2e:ep8": "jest --config jest.e2e.config.js --testPathPattern='ep8-story-runner.e2e.test.ts' --runInBand",
    "test:e2e:ep8:full": "jest --config jest.e2e.config.js --testPathPattern='ep8-full-path.e2e.test.ts' --runInBand",
    "test:e2e:st153:worktree": "jest --config jest.e2e.config.js --testPathPattern='st153-worktree-laptop.e2e.test.ts' --runInBand",
    "test:e2e:st158:mcp-worktree": "jest --config jest.e2e.config.js --testPathPattern='st158-mcp-orchestrated-worktree.e2e.test.ts' --runInBand",
    "test:e2e:st160:native-subagent": "jest --config jest.e2e.config.js --testPathPattern='st160-native-subagent.e2e.test.ts' --runInBand",
    "test:e2e:st161:real-mcp": "jest --config jest.e2e.config.js --testPathPattern='st161-real-mcp-commands.e2e.test.ts' --runInBand --testTimeout=180000",
    "test:e2e:st161:crud": "jest --config jest.e2e.config.js --testPathPattern='st161-mcp-crud.e2e.test.ts' --runInBand --testTimeout=300000",
    "test:e2e:st161:git": "jest --config jest.e2e.config.js --testPathPattern='st161-mcp-git.e2e.test.ts' --runInBand --testTimeout=300000",
    "test:e2e:st161:artifacts": "jest --config jest.e2e.config.js --testPathPattern='st161-mcp-artifacts.e2e.test.ts' --runInBand --testTimeout=300000",
    "test:e2e:st161:runner": "jest --config jest.e2e.config.js --testPathPattern='st161-mcp-runner.e2e.test.ts' --runInBand --testTimeout=300000",
    "test:e2e:st161:edge": "jest --config jest.e2e.config.js --testPathPattern='st161-mcp-edge-cases.e2e.test.ts' --runInBand --testTimeout=300000",
    "test:e2e:st161:all": "jest --config jest.e2e.config.js --testPathPattern='st161-' --runInBand --testTimeout=300000",
    "test:e2e:ep8:cleanup": "tsx src/e2e/ep8-story-runner/helpers/cleanup-orphans.ts",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "test:st323:unit": "jest --runInBand handlers/__tests__/transcript.handler.upload.test.ts",
    "test:st323:integration": "jest --config jest.integration.config.js --testPathPattern='upload-batch.integration.test.ts' --runInBand",
    "test:st323:e2e": "jest --config jest.integration.config.js --testPathPattern='upload-flow.e2e.test.ts' --runInBand",
    "typecheck": "tsc --noEmit",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "mcp:dev": "ts-node src/mcp/server.ts",
    "backfill:snapshots": "npx ts-node src/scripts/backfill-snapshots.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/websockets": "^11.0.0",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/auto-instrumentations-node": "^0.43.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.48.0",
    "@opentelemetry/resources": "^1.21.0",
    "@opentelemetry/sdk-node": "^0.48.0",
    "@opentelemetry/sdk-trace-node": "^1.21.0",
    "@opentelemetry/semantic-conventions": "^1.21.0",
    "@prisma/client": "^5.9.0",
    "@types/bull": "^3.15.9",
    "bcrypt": "^5.1.1",
    "bull": "^4.12.0",
    "chokidar": "^4.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "glob": "^10.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "openai": "^6.8.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "skott": "0.35.0",
    "socket.io": "^4.8.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0",
    "prisma": "^5.9.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6"
  }
}
