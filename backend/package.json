{
  "name": "@aistudio/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Vibe Studio Backend - NestJS REST API and MCP Server",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest src --maxWorkers=4",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --maxWorkers=4",
    "test:cov:summary": "jest --coverage --coverageReporters=text-summary --maxWorkers=4",
    "test:cov:html": "jest --coverage --coverageReporters=html,text-summary --maxWorkers=4 && echo '\nCoverage report generated at: backend/coverage/index.html'",
    "test:cov:execution": "jest src/mcp/servers/execution --coverage --coverageReporters=text,html --maxWorkers=2",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:unit:report": "jest --testPathIgnorePatterns='integration|e2e' --json --outputFile=../test-results/jest-unit-results.json",
    "test:integration:report": "jest --testPathPattern='integration' --json --outputFile=../test-results/jest-integration-results.json",
    "test:all": "npm test && npm run test:e2e:ep8",
    "test:e2e:ep8": "jest --config jest.e2e.config.js --testPathPattern='ep8-story-runner.e2e.test.ts' --runInBand",
    "test:e2e:ep8:full": "jest --config jest.e2e.config.js --testPathPattern='ep8-full-path.e2e.test.ts' --runInBand",
    "test:e2e:st153:worktree": "jest --config jest.e2e.config.js --testPathPattern='st153-worktree-laptop.e2e.test.ts' --runInBand",
    "test:e2e:st158:mcp-worktree": "jest --config jest.e2e.config.js --testPathPattern='st158-mcp-orchestrated-worktree.e2e.test.ts' --runInBand",
    "test:e2e:ep8:cleanup": "tsx src/e2e/ep8-story-runner/helpers/cleanup-orphans.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts",
    "db:seed:demo": "ts-node prisma/seed-demo.ts",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "mcp:dev": "ts-node src/mcp/server.ts",
    "backfill:snapshots": "npx ts-node src/scripts/backfill-snapshots.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.4.20",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^7.2.0",
    "@nestjs/websockets": "^10.4.20",
    "@prisma/client": "^5.9.0",
    "@types/bull": "^3.15.9",
    "bcrypt": "^5.1.1",
    "bull": "^4.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "glob": "^10.5.0",
    "ioredis": "^5.3.2",
    "openai": "^6.8.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0",
    "prisma": "^5.9.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6"
  }
}
