# Database Configuration (local development)
DATABASE_URL="postgresql://postgres:CHANGE_ME_POSTGRES_PASSWORD@localhost:5433/vibestudio?schema=public"

# Redis Configuration (for Bull queues - local development)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

# Alternative Redis URL format
REDIS_URL="redis://localhost:6380/0"

# JWT Configuration
JWT_SECRET="CHANGE_ME_JWT_SECRET"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_SECRET="CHANGE_ME_JWT_REFRESH_SECRET"
JWT_REFRESH_EXPIRES_IN="30d"

# Server Configuration
NODE_ENV="development"
PORT=3000

# Frontend Configuration
VITE_API_URL="http://localhost:3000"
VITE_WS_URL="ws://localhost:3000"

# MCP Server Configuration
MCP_LOG_LEVEL="info"

# Background Workers Configuration
BULL_CONCURRENCY=5
BULL_MAX_ATTEMPTS=3
CODE_ANALYSIS_ENABLED=true
CODE_ANALYSIS_BATCH_SIZE=10
CODE_ANALYSIS_MAX_COMPLEXITY=10
CODE_ANALYSIS_MIN_COVERAGE=80

# OpenAI Configuration (for embeddings)
# Replace with your actual OpenAI API key
OPENAI_API_KEY="your-openai-api-key-here"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Optional: Email configuration
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASSWORD=""
# NOTIFICATION_FROM_EMAIL="noreply@vibestudio.com"

# Optional: Sentry for error tracking
# SENTRY_DSN=""
