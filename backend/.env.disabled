# Database (use postgres service name for Docker)
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/vibestudio"

# Redis (use redis service name for Docker)
REDIS_URL="redis://redis:6379"

# JWT (matches main .env file)
JWT_SECRET="CHANGE_ME_JWT_SECRET"
JWT_EXPIRES_IN="7d"

# Server
NODE_ENV="production"
PORT=3000

# MCP
MCP_LOG_LEVEL="info"

# OpenAI (for embeddings)
OPENAI_API_KEY="your-api-key-here"

# Bull Queue
BULL_CONCURRENCY=5
