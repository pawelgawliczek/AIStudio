# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vibestudio"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-this-in-production"
JWT_EXPIRES_IN="7d"

# Server
NODE_ENV="development"
PORT=3000

# MCP
MCP_LOG_LEVEL="info"

# OpenAI (for embeddings)
OPENAI_API_KEY="your-api-key-here"

# Bull Queue
BULL_CONCURRENCY=5
