# Database Configuration (use postgres service name for Docker)
DATABASE_URL="postgresql://postgres:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/vibestudio"
POSTGRES_PASSWORD="CHANGE_ME_POSTGRES_PASSWORD"

# Redis Configuration (use redis service name for Docker)
REDIS_URL="redis://redis:6379"

# JWT Configuration (already secure random strings)
JWT_SECRET="CHANGE_ME_JWT_SECRET"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_SECRET="CHANGE_ME_JWT_REFRESH_SECRET"
JWT_REFRESH_EXPIRES_IN="30d"

# Server Configuration
NODE_ENV="production"
PORT=3000

# Frontend Configuration (using subdomain with HTTPS)
VITE_API_URL="https://vibestudio.example.com"
VITE_WS_URL="wss://vibestudio.example.com"

# MCP Server Configuration
MCP_LOG_LEVEL="info"

# Internal API Secret (ST-129) - Used by MCP handlers to call internal endpoints
INTERNAL_API_SECRET="CHANGE_ME_INTERNAL_API_SECRET"

# Background Workers Configuration
BULL_CONCURRENCY=5
BULL_MAX_ATTEMPTS=3

# OpenAI Configuration (for embeddings)
OPENAI_API_KEY="your-openai-api-key-here"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Optional: Sentry for error tracking
# SENTRY_DSN=""

# Optional: Email configuration
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASS=""
