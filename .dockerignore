# ST-115: Fixed .dockerignore patterns
# NOTE: Docker doesn't support **/ glob patterns - use explicit paths instead
# This reduces build context from ~500MB to ~20MB

# =============================================================================
# Node modules (explicit paths - **/ NOT supported by Docker)
# =============================================================================
node_modules/
backend/node_modules/
frontend/node_modules/
shared/node_modules/

# =============================================================================
# Build artifacts
# =============================================================================
dist/
backend/dist/
frontend/dist/
shared/dist/
*.tsbuildinfo

# =============================================================================
# Test & Coverage
# =============================================================================
coverage/
backend/coverage/
frontend/coverage/
playwright-report/
.playwright-mcp/
test-results/

# =============================================================================
# Git & IDE
# =============================================================================
.git/
.gitignore
.vscode/
.idea/

# =============================================================================
# Environment & Secrets
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
# Logs & Debug
# =============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
Thumbs.db

# =============================================================================
# Backups (large files - ST-70)
# =============================================================================
backups/

# =============================================================================
# Documentation (not needed in containers)
# =============================================================================
docs/
*.md
!README.md

# =============================================================================
# Worktrees (large directories)
# =============================================================================
worktrees/
