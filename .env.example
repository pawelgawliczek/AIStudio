# Database Configuration (Production Setup - Port 5433)
DATABASE_URL="postgresql://postgres:CHANGE_ME_POSTGRES_PASSWORD@localhost:5433/vibestudio?schema=public"

# Redis Configuration (Production Setup - Port 6380)
REDIS_URL="redis://localhost:6380"

# JWT Configuration
JWT_SECRET="change-this-to-a-secure-random-string-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-this-to-another-secure-random-string-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# Server Configuration
NODE_ENV="development"
PORT=3000

# Frontend Configuration
VITE_API_URL="http://localhost:3000"
VITE_WS_URL="ws://localhost:3000"

# MCP Server Configuration
MCP_LOG_LEVEL="info"

# Background Workers Configuration
BULL_CONCURRENCY=5
BULL_MAX_ATTEMPTS=3

# OpenAI Configuration (for embeddings)
OPENAI_API_KEY="your-openai-api-key-here"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Observability Configuration (ST-257)
OTEL_ENABLED="false"
OTEL_EXPORTER_OTLP_ENDPOINT="http://tempo:4318/v1/traces"
OTEL_SERVICE_NAME="aistudio-backend"

# Optional: Sentry for error tracking
# SENTRY_DSN=""

# Optional: Email configuration
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASS=""

# Transcript Cleanup Configuration (ST-348)
TRANSCRIPT_RETENTION_DAYS=7
